# AI Foundry Settings
AI_PROJECT_ENDPOINT=<ai_project_endpoint>
AI_MODEL_DEPLOYMENT_NAME=<ai_model_deployment_name>

# OpenAI Settings
OPENAI_API_KEY=<openai_api_key>
OPENAI_MODEL_ID=<openai_model_id>
OPENAI_ENDPOINT=<openai_endpoint>

# Embedding Settings (Azure OpenAI)
LLM_EMBEDDING_ENDPOINT=<azure_openai_embedding_endpoint>
LLM_EMBEDDING_MODEL=<azure_embedding_model_name>
LLM_EMBEDDING_APIKEY=<azure_openai_api_key>

# Azure Blob Storage Settings
AZURE_STORAGE_CONNECTION_STRING=<azure_storage_connection_string>
AZURE_STORAGE_CONTAINER=documentspdf

# Blob Container Names (for Azure Function)
DOCUMENTS_PDF_CONTAINER=documentspdf
DOCUMENT_PROCESSED_CONTAINER=documentprocessed
DOCUMENT_CHUNKS_CONTAINER=documentchunks

# Qdrant Vector Database Settings
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=<qdrant_api_key>

# Database Settings
DATABASE_URL=postgresql://user:password@localhost:5432/neotix_db

# JWT Settings
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_DELTA=1800
